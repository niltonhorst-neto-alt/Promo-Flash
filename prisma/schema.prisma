generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id      Int      @id @default(autoincrement())
  nome    String
  email   String   @unique
  pedidos Pedido[]
}

model Pedido {
  id         Int      @id @default(autoincrement())
  valorTotal Float
  usuarioId  Int

  usuario Usuario @relation(fields: [usuarioId], references: [id])
}